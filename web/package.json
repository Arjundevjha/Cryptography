{
  "name": "cryptography-museum",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "e2e": "playwright test",
    "run-e2e-script": "bash ../run_e2e_no_install.sh",
    "pytest": "python3 -m pytest api",
    "debug-aes": "PYTHONPATH=.. python3 -c \"from methods.modern import aes; from api.main import parse_aes_key; kb = parse_aes_key('1234567890123456', 'text'); c, n = aes.encrypt('Secret Message', kb); p = aes.decrypt(c, kb, n); print('Success decrypted:', p)\"",
    "run-e2e-full": "bash ../run_e2e_tests.sh"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vitest": "^4.1.8"
  }
}
