{
  "name": "cryptography-museum",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:all": "concurrently \"npm run dev\" \"PYTHONPATH=.. uvicorn api.main:app --port 8000 --reload\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently \"npm run start\" \"PYTHONPATH=.. uvicorn api.main:app --port 8000\"",
    "lint": "next lint",
    "test": "jest",
    "e2e": "playwright test",
    "run-e2e-script": "bash ../run_e2e_no_install.sh",
    "pytest": "python3 -m pytest api",
    "debug-aes": "PYTHONPATH=.. python3 -c \"from methods.modern import aes; from api.main import parse_aes_key; kb = parse_aes_key('1234567890123456', 'text'); c, n = aes.encrypt('Secret Message', kb); p = aes.decrypt(c, kb, n); print('Success decrypted:', p)\"",
    "run-e2e-full": "bash ../run_e2e_tests.sh"
  },
  "dependencies": {
    "@react-three/drei": "9.121.0",
    "@react-three/fiber": "8.17.14",
    "@react-three/postprocessing": "2.16.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "postprocessing": "6.36.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "three": "0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
